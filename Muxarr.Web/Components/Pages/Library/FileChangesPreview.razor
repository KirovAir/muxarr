@using Muxarr.Core.Models
@using Muxarr.Data.Entities

@* File-level (whole-container) changes, as a compact chip row beside the track
   tables. Pass Plan for what a conversion will do, or After for what it did.
   Add a case here as new container options land. *@
@if (_changes.Count > 0)
{
    <div class="d-flex flex-wrap gap-2 mb-3">
        @foreach (var change in _changes)
        {
            <ToolTip Tip="@change.Tooltip">
                <span
                    class="badge rounded-pill border @change.Css d-inline-flex align-items-center gap-1 fw-normal py-1 px-2">
                    <i class="bi @change.Icon"></i>@change.Label
                </span>
            </ToolTip>
        }
    </div>
}

@code {
    [Parameter] [EditorRequired] public MediaSnapshot Source { get; set; } = default!;
    [Parameter] public ConversionPlan? Plan { get; set; }

    /// <summary>The converted file, to report what happened instead of what was planned.</summary>
    [Parameter] public MediaSnapshot? After { get; set; }

    private sealed record Change(string Icon, string Label, string Tooltip, string Css);

    // Removals share the track table's red x-circle so the whole preview reads
    // as one language; value changes use the same info tone as track edits.
    private const string Removed = "bg-danger-subtle text-danger-emphasis border-danger-subtle";
    private const string Changed = "bg-info-subtle text-info-emphasis border-info-subtle";

    // Containers run a touch long past the last video frame even untrimmed.
    private const long TrimSlackMs = 1000;

    private List<Change> _changes = [];

    protected override void OnParametersSet()
    {
        var changes = new List<Change>();
        var done = After != null;

        if (Plan == null && !done)
        {
            _changes = changes;
            return;
        }

        if (done
                ? !string.IsNullOrEmpty(Source.Title) && string.IsNullOrEmpty(After!.Title)
                : Plan!.Title == "" && !string.IsNullOrEmpty(Source.Title))
        {
            changes.Add(new Change("bi-x-circle-fill", "File title",
                $"File title \"{Source.Title}\" {(done ? "removed" : "will be removed")}", Removed));
        }

        if (done ? Source.HasChapters && !After!.HasChapters : Plan!.HasChapters == false && Source.HasChapters)
        {
            changes.Add(new Change("bi-x-circle-fill", "Chapters",
                $"Chapter markers {(done ? "removed" : "will be removed")}", Removed));
        }

        if (done
                ? After!.DurationMs > 0 && Source.DurationMs - After.DurationMs > TrimSlackMs
                : Plan!.TrimToVideoLength)
        {
            changes.Add(new Change("bi-scissors", "Trim to video length",
                done
                    ? "Anything running past the end of the video was discarded"
                    : "Anything running past the end of the video will be discarded, "
                      + "if this conversion needs a remux",
                Changed));
        }

        _changes = changes;
    }

}
