@using Muxarr.Web.Attributes
@attribute [type: RenderModeInteractiveServer]

<div class="lpe-container">
    @for (var i = 0; i < Languages.Count; i++)
    {
        var index = i;
        var pref = Languages[index];
        var isFirst = index == 0;
        var isExpanded = _expandedIndex == index;
        var isDragOver = _dragOverIndex == index && _dragSourceIndex != index;
        var isOriginal = pref.IsOriginalLanguagePlaceholder;

        <div
            class="lpe-item @(isDragOver ? "lpe-item-dragover" : "") @(_dragSourceIndex == index ? "lpe-item-dragging" : "") @(isOriginal ? "lpe-item-original" : "")"
            draggable="true"
            @ondragstart="() => OnDragStart(index)"
            @ondragenter="() => OnDragEnter(index)"
            @ondragover:preventDefault
            @ondrop="() => OnDrop(index)"
            @ondragend="OnDragEnd">

            <i class="bi bi-grip-vertical lpe-drag-handle"></i>
            <span class="lpe-priority-number">@(index + 1)</span>

            @if (isOriginal)
            {
                <ToolTip
                    Tip="Matches the language a movie or show was originally made in. Works like a wildcard - automatically picks the right language per file using data from Sonarr/Radarr.">
                    <i class="bi bi-film lpe-original-icon"></i>
                </ToolTip>
                <span class="lpe-lang-name">Original Language</span>
            }
            else
            {
                <span class="lpe-lang-name">@pref.Name</span>
                <span class="lpe-lang-code">@pref.ThreeLetterCode</span>
            }

            <ToolTip Tip="Per-language settings">
                <button type="button"
                        class="lpe-icon-btn @(pref.HasOverrides ? "lpe-gear-active" : "") @(isExpanded ? "lpe-gear-expanded" : "")"
                        @onclick="() => ToggleExpanded(index)">
                    <i class="bi @(pref.HasOverrides ? "bi-gear-fill" : "bi-gear")"></i>
                </button>
            </ToolTip>

            <ToolTip Tip="Remove language">
                <button type="button" class="lpe-icon-btn lpe-remove-btn" @onclick="() => OnRemove(index)">
                    <i class="bi bi-x-lg"></i>
                </button>
            </ToolTip>
        </div>

        @if (isExpanded)
        {
            <div class="lpe-advanced-panel">
                <div class="row g-2">
                    <div class="col-6">
                        <ToolTip Tip="Limit the number of tracks kept for this language. The preferred track is kept first.">
                            <label class="lpe-advanced-label">Max tracks</label>
                        </ToolTip>
                        <select class="form-select form-select-sm"
                                value="@(pref.MaxTracks?.ToString() ?? "")"
                                @onchange="e => SetMaxTracks(pref, e.Value?.ToString())">
                            <option value="">Default (all)</option>
                            <option value="1">Keep 1 (best)</option>
                            <option value="2">Keep 2</option>
                            <option value="3">Keep 3</option>
                        </select>
                    </div>
                    <div class="col-6">
                        @if (IsAudio)
                        {
                            <ToolTip
                                Tip="When limiting tracks, choose what to keep: the most surround channels, lossless audio first, or the smallest file size.">
                                <label class="lpe-advanced-label">Quality preference</label>
                            </ToolTip>
                            <select class="form-select form-select-sm"
                                    value="@pref.QualityStrategy.ToString()"
                                    @onchange="e => SetQualityStrategy(pref, e.Value?.ToString())">
                                <option value="@nameof(AudioQualityStrategy.BestQuality)">Lossless first (default)</option>
                                <option value="@nameof(AudioQualityStrategy.MostChannels)">Most channels (surround)</option>
                                <option value="@nameof(AudioQualityStrategy.SmallestSize)">Smallest size</option>
                            </select>
                        }
                        else
                        {
                            <ToolTip
                                Tip="When limiting tracks, choose what to keep: text subtitles (SRT), image subtitles (PGS), or accessibility (SDH) tracks.">
                                <label class="lpe-advanced-label">Subtitle preference</label>
                            </ToolTip>
                            <select class="form-select form-select-sm"
                                    value="@pref.SubtitleStrategy.ToString()"
                                    @onchange="e => SetSubtitleStrategy(pref, e.Value?.ToString())">
                                <option value="@nameof(SubtitleQualityStrategy.TextFirst)">Text first (SRT, default)</option>
                                <option value="@nameof(SubtitleQualityStrategy.ImageFirst)">Image first (PGS)</option>
                                <option value="@nameof(SubtitleQualityStrategy.Accessibility)">Accessibility (SDH)</option>
                            </select>
                        }
                    </div>
                </div>
                <small class="lpe-advanced-hint">@RankingHint(pref)</small>
                @if (pref.HasOverrides)
                {
                    <button type="button" class="btn btn-link btn-sm text-muted p-0 mt-2"
                            @onclick="() => ClearOverrides(pref)">
                        <i class="bi bi-arrow-counterclockwise me-1"></i>Reset to defaults
                    </button>
                }
            </div>
        }
    }

    <div class="lpe-add-row">
        <div class="lpe-add-wrapper">
            <AutoComplete TItem="IsoLanguage"
                          SearchInput="@_searchInput"
                          OnSearchInput="OnSearchInput"
                          OnSelectItem="OnSelect">
                <ListTemplate>@context.Name@(context.NativeName != context.Name ? $" — {context.NativeName}" : "")@(context.ThreeLetterCode != null ? $" ({context.ThreeLetterCode.ToUpperInvariant()})" : "")</ListTemplate>
            </AutoComplete>
        </div>
        @if (!HasOriginalLanguage)
        {
            <ToolTip
                Tip="Matches the language a movie or show was originally made in. Works like a wildcard - automatically picks the right language per file using data from Sonarr/Radarr.">
                <button type="button" class="btn btn-link btn-sm text-muted p-0" @onclick="AddOriginalLanguage">
                    <i class="bi bi-film me-1"></i>Add original language
                </button>
            </ToolTip>
        }
    </div>
</div>

@code {
    [Parameter] [EditorRequired] public required List<LanguagePreference> Languages { get; set; }
    [Parameter] public MediaTrackType TrackType { get; set; }

    private bool IsAudio => TrackType == MediaTrackType.Audio;

    private string _searchInput = string.Empty;
    private int _expandedIndex = -1;
    private int _dragSourceIndex = -1;
    private int _dragOverIndex = -1;

    private bool HasOriginalLanguage => Languages.Any(l => l.IsOriginalLanguagePlaceholder);

    // --- Drag and drop ---

    private void OnDragStart(int index)
    {
        _dragSourceIndex = index;
        _dragOverIndex = -1;
        _expandedIndex = -1;
    }

    private void OnDragEnter(int index)
    {
        if (_dragSourceIndex >= 0 && _dragSourceIndex != index)
        {
            _dragOverIndex = index;
        }
    }

    private void OnDrop(int targetIndex)
    {
        if (_dragSourceIndex < 0 || _dragSourceIndex == targetIndex)
        {
            return;
        }

        var item = Languages[_dragSourceIndex];
        Languages.RemoveAt(_dragSourceIndex);
        Languages.Insert(targetIndex, item);

        _dragSourceIndex = -1;
        _dragOverIndex = -1;
    }

    private void OnDragEnd()
    {
        _dragSourceIndex = -1;
        _dragOverIndex = -1;
    }

    // --- Add / Remove ---

    private void OnSelect(IsoLanguage item)
    {
        _searchInput = string.Empty;
        if (Languages.All(l => l.Name != item.Name))
        {
            Languages.Add(new LanguagePreference(item));
        }
    }

    private void AddOriginalLanguage()
    {
        if (!HasOriginalLanguage)
        {
            Languages.Add(new LanguagePreference(IsoLanguage.OriginalLanguage));
        }
    }

    private void OnRemove(int index)
    {
        Languages.RemoveAt(index);

        if (_expandedIndex == index)
        {
            _expandedIndex = -1;
        }
        else if (_expandedIndex > index)
        {
            _expandedIndex--;
        }
    }

    private Task<List<IsoLanguage>> OnSearchInput(string input)
    {
        return Task.FromResult(IsoLanguage.Search(input).Take(10).ToList());
    }

    // --- Advanced panel ---

    private void ToggleExpanded(int index)
    {
        _expandedIndex = _expandedIndex == index ? -1 : index;
    }

    private static void SetMaxTracks(LanguagePreference pref, string? value)
    {
        pref.MaxTracks = int.TryParse(value, out var v) ? v : null;
    }

    private static void SetQualityStrategy(LanguagePreference pref, string? value)
    {
        pref.QualityStrategy = Enum.TryParse<AudioQualityStrategy>(value, out var v) ? v : AudioQualityStrategy.BestQuality;
    }

    private static void SetSubtitleStrategy(LanguagePreference pref, string? value)
    {
        pref.SubtitleStrategy = Enum.TryParse<SubtitleQualityStrategy>(value, out var v) ? v : SubtitleQualityStrategy.TextFirst;
    }

    private static void ClearOverrides(LanguagePreference pref)
    {
        pref.MaxTracks = null;
        pref.QualityStrategy = AudioQualityStrategy.BestQuality;
        pref.SubtitleStrategy = SubtitleQualityStrategy.TextFirst;
    }

    private string RankingHint(LanguagePreference pref)
    {
        if (IsAudio)
        {
            return pref.QualityStrategy switch
            {
                AudioQualityStrategy.MostChannels =>
                    "Most channels first (surround > stereo), then spatial & lossless. Commentary ranked lowest.",
                AudioQualityStrategy.SmallestSize =>
                    "Lossy > lossless, fewest channels first. Commentary ranked lowest.",
                _ =>
                    "Lossless + spatial > lossless > lossy, most channels as tiebreak. Commentary ranked lowest."
            };
        }

        return pref.SubtitleStrategy switch
        {
            SubtitleQualityStrategy.ImageFirst =>
                "Image (PGS) > text, then Regular > SDH > Forced. Commentary ranked lowest.",
            SubtitleQualityStrategy.Accessibility =>
                "SDH/HI first, then text > image. Keeps accessibility subtitles.",
            _ =>
                "Text > image, then Regular > SDH > Forced. Commentary ranked lowest."
        };
    }

}
