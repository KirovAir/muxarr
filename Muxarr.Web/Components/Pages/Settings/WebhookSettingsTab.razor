@using Muxarr.Core.Api
@using Muxarr.Core.Config

<p class="text-muted">Configure webhook integration so Sonarr and Radarr automatically trigger Muxarr when files are imported or renamed.</p>

@if (!_hasAnyArrConfigured)
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle me-2"></i>
        No Sonarr or Radarr connections configured. Set up your connections in the
        <a href="#" @onclick="ActivateArrTab" @onclick:preventDefault>*Arr Settings</a> tab first.
    </div>
}

<EditForm Model="Config" OnValidSubmit="HandleSubmit">
    <div class="border rounded p-4 mb-4">
        <h5 class="mb-3"><i class="bi bi-link-45deg me-2"></i>Webhook Settings</h5>

        <div class="mb-3">
            <label for="wh-muxarr-url" class="form-label">Muxarr URL</label>
            <InputText id="wh-muxarr-url" class="form-control" @bind-Value="Config.MuxarrUrl" />
            <small class="form-text text-muted">
                The URL that Sonarr/Radarr can reach Muxarr at. Example: <code>http://muxarr:8183</code>
            </small>
        </div>

        <div class="mb-3">
            <label for="wh-delay" class="form-label">Processing delay (seconds)</label>
            <InputNumber id="wh-delay" class="form-control" style="max-width: 200px;" @bind-Value="Config.DelaySeconds" />
            <small class="form-text text-muted">
                Wait before processing to avoid file locks with other services (Bazarr, etc.)
            </small>
        </div>

        <div class="mb-3 form-check form-switch">
            <InputCheckbox id="wh-autoqueue" class="form-check-input" @bind-Value="Config.AutoQueue" />
            <label for="wh-autoqueue" class="form-check-label">Auto-queue files for conversion</label>
            <br />
            <small class="form-text text-muted">When disabled, files are only scanned but not automatically queued.</small>
        </div>

        <div class="mb-3">
            <label class="form-label">API Key</label>
            <div class="input-group" style="max-width: 500px;">
                <input type="text" class="form-control" value="@Config.ApiKey" readonly />
            </div>
            <small class="form-text text-muted">
                Managed in the <a href="#" @onclick="ActivateApiTab" @onclick:preventDefault>API</a> tab.
            </small>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <WebhookConnector Name="Radarr" ConfigKey="@ArrConfig.RadarrKey"
                              GetWebhookUrl="@(() => WebhookUrl)"
                              Status="_radarrStatus" StatusChanged="s => _radarrStatus = s" />
        </div>
        <div class="col-md-6">
            <WebhookConnector Name="Sonarr" ConfigKey="@ArrConfig.SonarrKey"
                              GetWebhookUrl="@(() => WebhookUrl)"
                              Status="_sonarrStatus" StatusChanged="s => _sonarrStatus = s" />
        </div>
    </div>

    <div class="border rounded p-4 mb-4">
        <h5 class="mb-3"><i class="bi bi-info-circle me-2"></i>Manual Setup</h5>
        <p class="text-muted mb-2">If you prefer to configure webhooks manually in Sonarr/Radarr:</p>
        <ol class="text-muted">
            <li>Go to Settings &gt; Connect &gt; Add &gt; Webhook</li>
            <li>Set the URL to: <code>@WebhookUrl</code></li>
            <li>Set Method to <strong>POST</strong></li>
            <li>Enable <strong>On Import</strong> and <strong>On Rename</strong></li>
        </ol>
        @if (!string.IsNullOrEmpty(Config.ApiKey))
        {
            <p class="text-muted small"><i class="bi bi-shield-lock me-1"></i>The API key is included in the URL above as a query parameter.</p>
        }
    </div>

    <StickyBar>
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-save me-2"></i>Save Settings
        </button>
    </StickyBar>
</EditForm>

@code {
    [Inject] public required IDbContextFactory<AppDbContext> ContextFactory { get; set; }
    [Inject] public required IToastService ToastService { get; set; }
    [Inject] public required ArrApiClient ArrApi { get; set; }

    [CascadingParameter] public TabSet? TabSet { get; set; }

    private WebhookConfig Config { get; set; } = new();
    private bool _hasAnyArrConfigured;
    private WebhookConnector.ConnectStatus? _radarrStatus;
    private WebhookConnector.ConnectStatus? _sonarrStatus;

    private string WebhookUrl
    {
        get
        {
            if (string.IsNullOrWhiteSpace(Config.MuxarrUrl))
            {
                return "http://<muxarr-host>:8183/api/webhook";
            }

            var url = $"{Config.MuxarrUrl.TrimEnd('/')}/api/webhook";
            if (!string.IsNullOrEmpty(Config.ApiKey))
            {
                url += $"?apikey={Config.ApiKey}";
            }

            return url;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await using var context = await ContextFactory.CreateDbContextAsync();
        Config = context.Configs.GetOrDefault<WebhookConfig>();

        var radarrConfig = context.Configs.GetOrDefault<ArrConfig>(ArrConfig.RadarrKey);
        var sonarrConfig = context.Configs.GetOrDefault<ArrConfig>(ArrConfig.SonarrKey);

        _hasAnyArrConfigured =
            (!string.IsNullOrWhiteSpace(radarrConfig.Url) && !string.IsNullOrWhiteSpace(radarrConfig.ApiKey)) ||
            (!string.IsNullOrWhiteSpace(sonarrConfig.Url) && !string.IsNullOrWhiteSpace(sonarrConfig.ApiKey));

        _radarrStatus = await WebhookConnector.GetStatus(ArrApi, radarrConfig);
        _sonarrStatus = await WebhookConnector.GetStatus(ArrApi, sonarrConfig);
    }

    private void ActivateArrTab()
    {
        TabSet?.ActivateTab("*arrsettings");
    }

    private void ActivateApiTab()
    {
        TabSet?.ActivateTab("api");
    }

    private async Task HandleSubmit()
    {
        try
        {
            await using var context = await ContextFactory.CreateDbContextAsync();
            Config.MuxarrUrl = Config.MuxarrUrl.Trim().TrimEnd('/');
            context.Configs.Set(Config);
            await context.SaveChangesAsync();
            ToastService.ShowSuccess("Webhook settings saved.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Failed to save settings: {ex.Message}");
        }
    }
}
