@* Tri-state flag toggle for the batch editor: leave unchanged, turn on, turn off.
   The single-file modal's flags are plain booleans; across a batch "leave it
   alone" has to be expressible, and is the default. The +/- sign is the same
   one MediaTrackDetail puts on its flag delta badges, so the button and the
   preview read as the same vocabulary. *@
<ToolTip Tip="@Describe()">
    <button type="button" class="btn btn-sm @StateCss" @onclick="Cycle">
        @if (Value is { } flag)
        {
            <span class="me-1">@(flag ? "+" : "-")</span>
        }
        <i class="bi @Icon"></i>
    </button>
</ToolTip>

@code {
    [Parameter] [EditorRequired] public required string Icon { get; set; }
    [Parameter] [EditorRequired] public required string Tip { get; set; }
    [Parameter] public bool? Value { get; set; }
    [Parameter] public EventCallback<bool?> ValueChanged { get; set; }

    private string StateCss => Value switch
    {
        true => "btn-primary",
        false => "btn-secondary",
        _ => "btn-outline-secondary"
    };

    private string Describe() => Value switch
    {
        true => $"{Tip}. Currently: turn on.",
        false => $"{Tip}. Currently: turn off.",
        _ => $"{Tip}. Currently: leave unchanged."
    };

    private async Task Cycle()
    {
        Value = Value switch
        {
            null => true,
            true => false,
            _ => null
        };

        await ValueChanged.InvokeAsync(Value);
    }

}
